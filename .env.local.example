# Supabase (database + file storage)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-supabase-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<your-supabase-service-role-key>"

# Anthropic AI
ANTHROPIC_API_KEY="<your-anthropic-api-key>"

# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
MAX_PDF_SIZE_MB=50

# Support email
RESEND_API_KEY="<your-resend-api-key>"
SUPPORT_EMAIL_TO="support@example.com"
SUPPORT_EMAIL_FROM="Insulation Takeoff <support@example.com>"

# Extraction
NEXT_PUBLIC_DEFAULT_EXTRACTION_MODE="ocr"  # "ocr" or "vision" — kill-switch for rollback
PDFENGINE_BASE_URL="http://localhost:8000"
PDFENGINE_API_KEY=""
